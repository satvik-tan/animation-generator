# ── Database ──────────────────────────────────────────────────────────────────
# Neon / Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Hostname of your Redis instance ("redis" inside Docker Compose, or managed Redis host)
REDIS_HOST=redis
REDIS_PORT=6379

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys (use sk_live_... for production)
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Google Gemini  – https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq           – https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS S3 (video storage) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to false in production
DEV_MODE=false
